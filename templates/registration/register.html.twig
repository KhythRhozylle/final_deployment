{% extends 'base_landing.html.twig' %}

{% block title %}Register - Florynn Handmade Bouquets{% endblock %}

{% block body %}
<div style="max-width: 500px; margin: 60px auto; padding: 40px; background: white; border-radius: 16px; box-shadow: 0 8px 32px rgba(195, 90, 122, 0.15);">
    <h1 style="text-align: center; color: #C35A7A; margin-bottom: 30px; font-size: 2rem;">📝 Create Account</h1>

    {% if demo_mode %}
        <div style="background: #fff3cd; color: #856404; padding: 12px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #ffc107; font-size: 0.95rem;">
            <strong>Demo mode</strong> — no verification email. After you register you go straight to the shop.
        </div>
    {% endif %}
    
    {% for message in app.flashes('success') %}
        <div style="background: #d4edda; color: #155724; padding: 12px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #28a745;">
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div style="background: #f8d7da; color: #721c24; padding: 12px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #dc3545;">
            {{ message }}
        </div>
    {% endfor %}

    {{ form_start(registrationForm, {'attr': {'style': 'display: flex; flex-direction: column; gap: 20px;'}}) }}
        {{ form_row(registrationForm.name, {
            'attr': {
                'style': 'width: 100%; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 1rem; transition: border-color 0.3s;',
                'onfocus': "this.style.borderColor='#C35A7A'",
                'onblur': "this.style.borderColor='#e0e0e0'"
            },
            'label_attr': {'style': 'display: block; margin-bottom: 8px; color: #C35A7A; font-weight: 500;'}
        }) }}

        {{ form_row(registrationForm.email, {
            'attr': {
                'style': 'width: 100%; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 1rem; transition: border-color 0.3s;',
                'onfocus': "this.style.borderColor='#C35A7A'",
                'onblur': "this.style.borderColor='#e0e0e0'"
            },
            'label_attr': {'style': 'display: block; margin-bottom: 8px; color: #C35A7A; font-weight: 500;'}
        }) }}

        {{ form_row(registrationForm.username, {
            'attr': {
                'style': 'width: 100%; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 1rem; transition: border-color 0.3s;',
                'onfocus': "this.style.borderColor='#C35A7A'",
                'onblur': "this.style.borderColor='#e0e0e0'"
            },
            'label_attr': {'style': 'display: block; margin-bottom: 8px; color: #C35A7A; font-weight: 500;'}
        }) }}

        {{ form_row(registrationForm.plainPassword.first, {
            'attr': {
                'style': 'width: 100%; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 1rem; transition: border-color 0.3s;',
                'onfocus': "this.style.borderColor='#C35A7A'",
                'onblur': "this.style.borderColor='#e0e0e0'"
            },
            'label_attr': {'style': 'display: block; margin-bottom: 8px; color: #C35A7A; font-weight: 500;'}
        }) }}

        {{ form_row(registrationForm.plainPassword.second, {
            'attr': {
                'style': 'width: 100%; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 1rem; transition: border-color 0.3s;',
                'onfocus': "this.style.borderColor='#C35A7A'",
                'onblur': "this.style.borderColor='#e0e0e0'"
            },
            'label_attr': {'style': 'display: block; margin-bottom: 8px; color: #C35A7A; font-weight: 500;'}
        }) }}

        <div style="display: flex; align-items: start; gap: 10px;">
            {{ form_widget(registrationForm.agreeTerms, {
                'attr': {
                    'style': 'margin-top: 5px; width: 18px; height: 18px; cursor: pointer;'
                }
            }) }}
            {{ form_label(registrationForm.agreeTerms, null, {
                'label_attr': {'style': 'color: #555; font-size: 0.9rem; cursor: pointer;'}
            }) }}
        </div>
        {{ form_errors(registrationForm.agreeTerms) }}

        <button 
            type="submit" 
            style="width: 100%; padding: 14px; background: linear-gradient(135deg, #C35A7A 0%, #D97E9B 100%); color: white; border: none; border-radius: 8px; font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: all 0.3s; margin-top: 10px;"
            onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(195, 90, 122, 0.4)'"
            onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'"
        >
            Register
        </button>
    {{ form_end(registrationForm) }}

    <div style="text-align: center; margin-top: 25px; color: #777;">
        <p style="margin: 0 0 10px 0;">Already have an account?</p>
        <a href="{{ path('app_login') }}" style="color: #C35A7A; text-decoration: none; font-weight: 600;">Sign In →</a>
    </div>

</div>
{% endblock %}

