<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Florynn Handmade Bouquets{% endblock %}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

        <style>
            :root {
                /* Bouquet floral theme (pastel + boutique) */
                --primary: #C35A7A;    /* rose */
                --primary-2: #E79AAE;  /* blush */
                --primary-3: #F2C6A5;  /* peach */
                --nav-bg: #C35A7A;
                --text: #2C1F24;       /* soft plum */
                --muted: #6F5B63;
                --surface: #ffffff;
                --surface-2: #FFF7FA;  /* cream-pink */
                --shadow: 0 10px 28px rgba(44, 31, 36, 0.12);
            }

            * { margin: 0; padding: 0; box-sizing: border-box; }

            body {
                font-family: 'Poppins', sans-serif;
                background-color: var(--surface-2);
                color: var(--text);
            }

            /* NAVBAR */
            nav {
                width: 100%;
                background: linear-gradient(90deg, #C35A7A 0%, #D97E9B 40%, #F2C6A5 100%);
                display: flex;
                align-items: center;
                padding: 0 40px;
                height: 64px;
                position: sticky;
                top: 0;
                z-index: 1000;
                box-shadow: var(--shadow);
            }

            /* LOGO */
            .logo {
                display: flex;
                align-items: center;
                gap: 10px;
                font-size: 0.95rem;
                font-weight: 700;
                color: rgba(255, 255, 255, 0.92);
                letter-spacing: 1.8px;
                text-transform: uppercase;
                white-space: nowrap;
                flex-shrink: 0;
                text-decoration: none;
            }

            .logo-icon {
                width: 140px;
                height: auto;
                border-radius: 0;
                object-fit: contain;
                flex-shrink: 0;
                transition: transform 0.3s ease;
            }

            .logo:hover .logo-icon {
                transform: rotate(-10deg) scale(1.1);
            }

            /* CENTER NAV LINKS */
            .nav-center {
                flex: 1;
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 2px;
            }

            .nav-center a {
                color: rgba(255, 255, 255, 0.92);
                font-size: 0.85rem;
                font-weight: 500;
                padding: 8px 16px;
                border-radius: 6px;
                text-decoration: none;
                letter-spacing: 0.4px;
                transition: background 0.2s ease, transform 0.2s ease;
                position: relative;
            }

            .nav-center a::after {
                content: '';
                position: absolute;
                bottom: 4px;
                left: 50%;
                transform: translateX(-50%) scaleX(0);
                width: 60%;
                height: 2px;
                background: rgba(255, 255, 255, 0.78);
                border-radius: 2px;
                transition: transform 0.25s ease;
            }

            .nav-center a:hover::after { transform: translateX(-50%) scaleX(1); }
            .nav-center a:hover { background: rgba(255,255,255,0.12); }

            /* RIGHT AUTH BUTTONS */
            .nav-right {
                display: flex;
                align-items: center;
                gap: 8px;
                flex-shrink: 0;
            }

            .nav-right a {
                display: flex;
                align-items: center;
                gap: 7px;
                font-size: 0.83rem;
                font-weight: 600;
                padding: 7px 16px;
                border-radius: 20px;
                text-decoration: none;
                letter-spacing: 0.3px;
                transition: all 0.25s ease;
            }

            .nav-right a i {
                font-size: 0.8rem;
            }

            /* Sign In — outlined style */
            .btn-signup {
                color: rgba(255, 255, 255, 0.92);
                border: 1.5px solid rgba(255, 255, 255, 0.62);
                background: transparent;
            }

            .btn-signup:hover {
                background: rgba(255, 255, 255, 0.16);
                border-color: #fff;
                transform: translateY(-1px);
                box-shadow: 0 10px 22px rgba(44, 31, 36, 0.18);
            }

            /* Register — filled style */
            .btn-register {
                color: var(--primary);
                background: rgba(255, 255, 255, 0.92);
                border: 1.5px solid transparent;
            }

            .btn-register:hover {
                background: #ffffff;
                transform: translateY(-1px);
                box-shadow: 0 12px 26px rgba(44, 31, 36, 0.18);
            }

            /* Logout */
            .btn-logout {
                color: rgba(255, 255, 255, 0.92);
                border: 1.5px solid rgba(255, 255, 255, 0.55);
                background: transparent;
            }

            .btn-logout:hover {
                background: rgba(255, 255, 255, 0.16);
                transform: translateY(-1px);
            }

            /* HAMBURGER MENU */
            .hamburger {
                display: none;
                flex-direction: column;
                cursor: pointer;
                gap: 4px;
                padding: 8px;
                border-radius: 4px;
                transition: background 0.2s ease;
            }
            .hamburger:hover { background: rgba(255,255,255,0.12); }
            .hamburger span {
                width: 24px;
                height: 2px;
                background: #fff;
                transition: all 0.3s ease;
            }
            .hamburger.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
            .hamburger.active span:nth-child(2) { opacity: 0; }
            .hamburger.active span:nth-child(3) { transform: rotate(-45deg) translate(7px, -6px); }

            /* Mobile nav overlay */
            .nav-overlay {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0,0,0,0.8);
                z-index: 999;
                display: none;
                justify-content: center;
                align-items: center;
            }
            .nav-overlay.active { display: flex; }

            .nav-mobile {
                background: var(--primary);
                padding: 40px;
                border-radius: 12px;
                text-align: center;
                max-width: 300px;
                width: 90%;
            }
            .nav-mobile a {
                display: block;
                color: #fff;
                text-decoration: none;
                font-size: 1.2rem;
                margin: 20px 0;
                transition: color 0.2s ease;
            }
            .nav-mobile a:hover { color: var(--primary-2); }

            /* PAGE CONTENT */
            main { min-height: calc(100vh - 200px); }

            /* Footer */
            footer {
                background: linear-gradient(180deg, #2C1F24 0%, #24191D 100%);
                color: rgba(255, 255, 255, 0.78);
                text-align: center;
                padding: 20px;
                font-size: 13px;
                margin-top: 40px;
                letter-spacing: 0.3px;
            }

            /* Responsive */
            @media (max-width: 600px) {
                nav {
                    justify-content: space-between;
                    padding: 12px 20px;
                }

                .logo {
                    font-size: 0.8rem;
                }

                .logo-icon {
                    width: 100px;
                }

                .nav-center {
                    display: none;
                }

                .nav-right {
                    display: none;
                }

                .hamburger {
                    display: flex;
                }
            }
        </style>
    </head>

    <body>
        <nav>
            <a class="logo" href="#">
                <img src="{{ asset('image/florynn.png') }}" alt="Florynn Handmade Bouquets Logo" class="logo-icon">
            </a>

            {% if app.user %}
                <div class="nav-center">
                    <a href="{{ path('app_staff_home') }}">Home</a>
                    <a href="{{ path('app_about_us') }}">About Us</a>
                    <a href="{{ path('app_our_history') }}">Our History</a>
                    <a href="{{ path('app_products') }}">Our Bouquets</a>
                    <a href="{{ path('app_contact_us') }}">Contact Us</a>
                </div>
                <div class="nav-right">
                    <a href="{{ path('app_logout') }}" class="btn-logout">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </a>
                </div>
            {% else %}
                <div class="nav-center">
                    <a href="{{ path('app_home') }}">Home</a>
                    <a href="{{ path('app_about_us') }}">About Us</a>
                    <a href="{{ path('app_our_history') }}">Our History</a>
                    <a href="{{ path('app_products') }}">Our Bouquets</a>
                    <a href="{{ path('app_contact_us') }}">Contact Us</a>
                </div>
                <div class="nav-right">
                        <a href="{{ path('app_login') }}" class="btn-signup">
                        <i class="fas fa-user-circle"></i> Sign In
                    </a>
                    <a href="{{ path('app_register') }}" class="btn-register">
                        <i class="fas fa-user-plus"></i> Register
                    </a>
                </div>
            {% endif %}

            <div class="hamburger" onclick="toggleMenu()">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </nav>

        <!-- Mobile nav overlay -->
        <div class="nav-overlay" id="navOverlay" onclick="closeMenu()">
            <div class="nav-mobile">
                {% if app.user %}
                    <a href="{{ path('app_staff_home') }}" onclick="closeMenu()">Home</a>
                    <a href="{{ path('app_about_us') }}" onclick="closeMenu()">About Us</a>
                    <a href="{{ path('app_our_history') }}" onclick="closeMenu()">Our History</a>
                    <a href="{{ path('app_products') }}" onclick="closeMenu()">Our Bouquets</a>
                    <a href="{{ path('app_contact_us') }}" onclick="closeMenu()">Contact Us</a>
                    <a href="{{ path('app_logout') }}" onclick="closeMenu()">Logout</a>
                {% else %}
                    <a href="{{ path('app_home') }}" onclick="closeMenu()">Home</a>
                    <a href="{{ path('app_about_us') }}" onclick="closeMenu()">About Us</a>
                    <a href="{{ path('app_our_history') }}" onclick="closeMenu()">Our History</a>
                    <a href="{{ path('app_products') }}" onclick="closeMenu()">Our Bouquets</a>
                    <a href="{{ path('app_contact_us') }}" onclick="closeMenu()">Contact Us</a>
                    <a href="{{ path('app_login') }}" onclick="closeMenu()">Sign In</a>
                    <a href="{{ path('app_register') }}" onclick="closeMenu()">Register</a>
                {% endif %}
            </div>
        </div>

        <main>
            {% block body %}{% endblock %}
        </main>

        <footer>
            &copy; 2025 Florynn Handmade Bouquets | All rights reserved 🌸
        </footer>

        <script>
        // Hamburger menu functions
        function toggleMenu() {
            const hamburger = document.querySelector('.hamburger');
            const overlay = document.getElementById('navOverlay');
            hamburger.classList.toggle('active');
            overlay.classList.toggle('active');
        }

        function closeMenu() {
            const hamburger = document.querySelector('.hamburger');
            const overlay = document.getElementById('navOverlay');
            hamburger.classList.remove('active');
            overlay.classList.remove('active');
        }
        </script>
    </body>
</html>