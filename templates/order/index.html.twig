{% extends 'base.html.twig' %}

{% block title %}Orders - Florynn Handmade Bouquets{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css">
{% endblock %}

{% block body %}
<style>
    .orders-container {
        padding: 30px;
        max-width: 1400px;
        margin: 0 auto;
        animation: fadeIn 0.5s ease-in-out;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Header Section */
    .orders-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .orders-header h1 {
        font-size: 1.6rem;
        font-weight: 700;
        color: #3E2723;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .header-actions {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .btn-add {
        background: linear-gradient(135deg, #8B5E3C 0%, #A0724E 100%);
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all 0.3s ease;
        box-shadow: 0 3px 10px rgba(139, 94, 60, 0.3);
        border: none;
        cursor: pointer;
    }

    .btn-add:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 16px rgba(139, 94, 60, 0.4);
    }

    /* Stats Overview */
    .orders-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
        margin-bottom: 20px;
    }

    .stat-box {
        background: white;
        border-radius: 10px;
        padding: 16px;
        box-shadow: 0 2px 10px rgba(139, 94, 60, 0.08);
        border-left: 3px solid;
        transition: all 0.3s ease;
    }

    .stat-box:hover {
        transform: translateY(-2px);
        box-shadow: 0 3px 12px rgba(139, 94, 60, 0.12);
    }

    .stat-box.pending { border-left-color: #FF9800; }
    .stat-box.completed { border-left-color: #4CAF50; }
    .stat-box.cancelled { border-left-color: #F44336; }
    .stat-box.total { border-left-color: #2196F3; }

    .stat-box h3 {
        font-size: 0.75rem;
        color: #8B5E3C;
        margin: 0 0 6px 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
    }

    .stat-box .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #3E2723;
        margin: 0;
    }

    /* DataTable Container */
    .table-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 3px 16px rgba(139, 94, 60, 0.08);
        border: 1px solid rgba(139, 94, 60, 0.1);
        overflow: hidden;
        padding: 20px;
    }

    /* DataTables Custom Styling */
    .dataTables_wrapper {
        font-family: 'Poppins', sans-serif !important;
    }

    .dataTables_wrapper .dataTables_length select {
        padding: 6px 12px;
        border: 1px solid rgba(139, 94, 60, 0.2);
        border-radius: 6px;
        font-size: 0.85rem;
        color: #3E2723;
        background: white;
        margin: 0 5px;
    }

    .dataTables_wrapper .dataTables_filter input {
        padding: 8px 14px;
        border: 1px solid rgba(139, 94, 60, 0.2);
        border-radius: 8px;
        font-size: 0.85rem;
        color: #3E2723;
        background: white;
        margin-left: 8px;
    }

    .dataTables_wrapper .dataTables_filter input:focus {
        outline: none;
        border-color: #8B5E3C;
        box-shadow: 0 0 0 2px rgba(139, 94, 60, 0.1);
    }

    /* Table Styles */
    table.dataTable {
        width: 100% !important;
        border-collapse: collapse;
        margin-top: 10px !important;
    }

    table.dataTable thead {
        background: linear-gradient(135deg, #8B5E3C 0%, #A0724E 100%);
        color: white;
    }

    table.dataTable thead th {
        padding: 12px 16px !important;
        text-align: left;
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        white-space: nowrap;
        border-bottom: none !important;
    }

    table.dataTable tbody tr {
        border-bottom: 1px solid rgba(139, 94, 60, 0.1);
        transition: all 0.2s ease;
    }

    table.dataTable tbody tr:hover {
        background: rgba(139, 94, 60, 0.03) !important;
    }

    table.dataTable tbody td {
        padding: 12px 16px !important;
        font-size: 0.85rem;
        color: #3E2723;
    }

    /* Order ID Badge */
    .order-id {
        font-weight: 600;
        color: #8B5E3C;
        font-family: 'Courier New', monospace;
        font-size: 0.85rem;
    }

    /* Status Badge */
    .status-badge {
        padding: 4px 10px;
        border-radius: 16px;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: capitalize;
        display: inline-block;
        white-space: nowrap;
    }

    .status-badge.pending {
        background: #FFF3E0;
        color: #E65100;
    }

    .status-badge.processing {
        background: #E3F2FD;
        color: #1565C0;
    }

    .status-badge.completed {
        background: #E8F5E9;
        color: #2E7D32;
    }

    .status-badge.cancelled {
        background: #FFEBEE;
        color: #C62828;
    }

    .status-badge.delivered {
        background: #F3E5F5;
        color: #6A1B9A;
    }

    .status-badge.confirmed {
        background: #E8F5E9;
        color: #2E7D32;
    }

    .status-badge.preparing {
        background: #E3F2FD;
        color: #1565C0;
    }

    .status-badge.out_for_delivery {
        background: #E1F5FE;
        color: #0277BD;
    }

    .payment-badge {
        padding: 4px 10px;
        border-radius: 16px;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: capitalize;
        display: inline-block;
        white-space: nowrap;
    }

    .payment-badge.paid {
        background: #E8F5E9;
        color: #2E7D32;
    }

    .payment-badge.pending_verification {
        background: #FFF3E0;
        color: #E65100;
    }

    .payment-badge.unpaid {
        background: #FFEBEE;
        color: #C62828;
    }

    .payment-badge.cash_on_delivery {
        background: #E3F2FD;
        color: #1565C0;
    }

    .mobile-pending-panel {
        background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
        border: 1px solid #FFE082;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 24px;
    }

    .mobile-pending-panel h2 {
        font-size: 1.1rem;
        color: #E65100;
        margin: 0 0 12px;
    }

    .mobile-order-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: white;
        padding: 12px 16px;
        border-radius: 8px;
        margin-bottom: 8px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .btn-review {
        background: #8B5E3C;
        color: white;
        padding: 8px 16px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .btn-review:hover { background: #6D4C41; color: white; }

    .source-badge {
        font-size: 0.7rem;
        background: #E3F2FD;
        color: #1565C0;
        padding: 2px 8px;
        border-radius: 10px;
        margin-left: 6px;
    }

    /* Price Display */
    .price {
        font-weight: 600;
        color: #2E7D32;
        font-size: 0.85rem;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 6px;
    }

    .btn-action {
        padding: 5px 10px;
        border-radius: 5px;
        text-decoration: none;
        font-size: 0.75rem;
        font-weight: 500;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        white-space: nowrap;
    }

    .btn-view {
        background: #E3F2FD;
        color: #1565C0;
    }

    .btn-view:hover {
        background: #BBDEFB;
        transform: translateY(-1px);
    }

    .btn-edit {
        background: #FFF3E0;
        color: #E65100;
    }

    .btn-edit:hover {
        background: #FFE0B2;
        transform: translateY(-1px);
    }

    .status-cell {
        display: flex;
        flex-direction: column;
        gap: 8px;
        align-items: flex-start;
    }

    .status-actions {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .btn-status {
        padding: 4px 10px;
        border: none;
        border-radius: 5px;
        font-size: 0.72rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: all 0.2s ease;
    }

    .btn-status-accept {
        background: #E8F5E9;
        color: #2E7D32;
    }

    .btn-status-accept:hover {
        background: #C8E6C9;
    }

    .btn-status-cancel {
        background: #FFEBEE;
        color: #C62828;
    }

    .btn-status-cancel:hover {
        background: #FFCDD2;
    }

    /* DataTables Pagination */
    .dataTables_wrapper .dataTables_paginate .paginate_button {
        padding: 6px 12px !important;
        margin: 0 2px;
        border-radius: 6px !important;
        border: 1px solid rgba(139, 94, 60, 0.2) !important;
        background: white !important;
        color: #6D4C41 !important;
        font-size: 0.85rem;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
        background: #8B5E3C !important;
        color: white !important;
        border-color: #8B5E3C !important;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button.current {
        background: #8B5E3C !important;
        color: white !important;
        border-color: #8B5E3C !important;
    }

    /* DataTables Info */
    .dataTables_wrapper .dataTables_info {
        font-size: 0.85rem;
        color: #6D4C41;
        padding-top: 10px;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 50px 20px;
        color: #8B5E3C;
    }

    .empty-state i {
        font-size: 3rem;
        margin-bottom: 16px;
        opacity: 0.3;
    }

    .empty-state h3 {
        font-size: 1.2rem;
        color: #3E2723;
        margin: 0 0 8px 0;
    }

    .empty-state p {
        margin: 0 0 20px 0;
        font-size: 0.9rem;
        color: #6D4C41;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .orders-container {
            padding: 16px;
        }

        .orders-header h1 {
            font-size: 1.4rem;
        }

        .orders-stats {
            grid-template-columns: repeat(2, 1fr);
        }

        .table-container {
            padding: 12px;
        }
    }

    @media (max-width: 480px) {
        .orders-stats {
            grid-template-columns: 1fr;
        }
    }

    .orders-live-toast {
        position: fixed;
        top: 20px;
        right: 24px;
        z-index: 9999;
        background: #2E7D32;
        color: white;
        padding: 14px 20px;
        border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
        font-size: 0.9rem;
        font-weight: 600;
        display: none;
        align-items: center;
        gap: 10px;
        animation: slideIn 0.3s ease;
    }

    .orders-live-toast.show { display: flex; }

    .orders-live-indicator {
        font-size: 0.75rem;
        color: #6D4C41;
        margin-left: 12px;
        font-weight: 500;
    }

    @keyframes slideIn {
        from { transform: translateX(100%); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }
</style>

<div class="orders-container">
    <!-- Header -->
    <div id="orders-live-toast" class="orders-live-toast" role="status" aria-live="polite">
        <i class="fas fa-bell"></i>
        <span id="orders-live-toast-text">New order received</span>
    </div>

    <div class="orders-header">
        <h1>
            <i class="fas fa-shopping-cart"></i> Orders Management
            <span class="orders-live-indicator" id="orders-live-indicator">Live updates on</span>
        </h1>
        <div class="header-actions">
            <a href="{{ path('app_order_new') }}" class="btn-add">
                <i class="fas fa-plus"></i> New Order
            </a>
        </div>
    </div>

    {% include 'order/_stats.html.twig' %}
    {% include 'order/_pending_mobile.html.twig' %}

    <!-- Orders DataTable -->
    <div class="table-container">
        {% if orders|length > 0 %}
            <table id="ordersTable" class="display responsive nowrap" style="width:100%">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Source</th>
                        <th>Customer</th>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th>Payment</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="orders-live-tbody">
                {% include 'order/_table_rows.html.twig' %}
                </tbody>
            </table>
        {% else %}
            <div class="empty-state">
                <i class="fas fa-shopping-cart"></i>
                <h3>No Orders Yet</h3>
                <p>Start by creating your first order</p>
                <a href="{{ path('app_order_new') }}" class="btn-add">
                    <i class="fas fa-plus"></i> Create First Order
                </a>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>
    
    <script>
        (function () {
            const LIVE_URL = {{ path('app_order_live_updates')|json_encode|raw }};
            let liveRevision = {{ liveRevision|default(0) }};
            let ordersDataTable = null;

            function initOrdersDataTable() {
                const $table = $('#ordersTable');
                if (!$table.length) return;

                if ($.fn.DataTable.isDataTable($table)) {
                    $table.DataTable().destroy();
                }

                ordersDataTable = $table.DataTable({
                    responsive: true,
                    pageLength: 10,
                    lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, 'All']],
                    order: [[7, 'desc'], [0, 'desc']],
                    columnDefs: [
                        { orderable: false, targets: [8] },
                        { type: 'date', targets: [7] },
                    ],
                    language: {
                        search: 'Search Orders:',
                        lengthMenu: 'Show _MENU_ orders',
                        info: 'Showing _START_ to _END_ of _TOTAL_ orders',
                        infoEmpty: 'No orders available',
                        infoFiltered: '(filtered from _MAX_ total orders)',
                        zeroRecords: 'No matching orders found',
                    },
                    dom: '<"top"lf>rt<"bottom"ip><"clear">',
                });
            }

            function showLiveToast(message) {
                const toast = document.getElementById('orders-live-toast');
                const text = document.getElementById('orders-live-toast-text');
                if (!toast || !text) return;
                text.textContent = message;
                toast.classList.add('show');
                setTimeout(() => toast.classList.remove('show'), 5000);
            }

            function applyLiveUpdate(payload) {
                const statsHost = document.getElementById('orders-live-stats');
                if (statsHost && payload.statsHtml) {
                    statsHost.outerHTML = payload.statsHtml;
                }

                const pendingHost = document.getElementById('orders-live-pending');
                if (pendingHost && payload.pendingHtml !== undefined) {
                    pendingHost.outerHTML = payload.pendingHtml;
                }

                const tbody = document.getElementById('orders-live-tbody');
                if (tbody && payload.tableRowsHtml !== undefined) {
                    tbody.innerHTML = payload.tableRowsHtml;
                    initOrdersDataTable();
                }

                const prevPending = parseInt(document.body.dataset.pendingMobile || '0', 10);
                const nextPending = payload.pendingMobileCount || 0;
                document.body.dataset.pendingMobile = String(nextPending);

                const prevCount = parseInt(document.body.dataset.orderCount || '0', 10);
                const nextCount = payload.orderCount ?? prevCount;
                document.body.dataset.orderCount = String(nextCount);

                if (nextPending > prevPending || nextCount > prevCount) {
                    showLiveToast('New mobile order — review pending approval');
                } else {
                    showLiveToast('Orders updated');
                }
            }

            async function pollOrdersLive() {
                try {
                    const res = await fetch(LIVE_URL, {
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        credentials: 'same-origin',
                    });
                    if (!res.ok) return;
                    const data = await res.json();
                    if (data.revision === liveRevision) return;
                    liveRevision = data.revision;
                    applyLiveUpdate(data);
                } catch (e) {
                    console.warn('Live order poll failed', e);
                }
            }

            $(document).ready(function () {
                document.body.dataset.pendingMobile = '{{ pendingMobileGroups|length }}';
                document.body.dataset.orderCount = '{{ orders|length }}';
                initOrdersDataTable();
                pollOrdersLive();
                setInterval(pollOrdersLive, 3000);
                document.addEventListener('visibilitychange', function () {
                    if (!document.hidden) pollOrdersLive();
                });
            });
        })();
    </script>
{% endblock %}