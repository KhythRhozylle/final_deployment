{% extends 'base.html.twig' %}

{% block title %}Contact inquiries{% endblock %}

{% block body %}
<div style="padding: 24px; max-width: 960px;">
    <h1 style="margin-bottom: 8px;"><i class="fas fa-envelope"></i> Contact inquiries</h1>
    <p style="color: #666; margin-bottom: 24px;">Messages from the mobile app and website contact forms.</p>

    {% if inquiries is empty %}
        <p>No inquiries yet.</p>
    {% else %}
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #f5f0eb; text-align: left;">
                    <th style="padding: 10px;">Date</th>
                    <th style="padding: 10px;">Source</th>
                    <th style="padding: 10px;">Name</th>
                    <th style="padding: 10px;">Email</th>
                    <th style="padding: 10px;">Message</th>
                </tr>
            </thead>
            <tbody>
                {% for row in inquiries %}
                <tr style="border-bottom: 1px solid #eee;">
                    <td style="padding: 10px; white-space: nowrap;">{{ row.createdAt|date('Y-m-d H:i') }}</td>
                    <td style="padding: 10px;">{{ row.source }}</td>
                    <td style="padding: 10px;">{{ row.name }}</td>
                    <td style="padding: 10px;">{{ row.email }}</td>
                    <td style="padding: 10px;">{{ row.message|length > 120 ? row.message|slice(0, 120) ~ '…' : row.message }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>
{% endblock %}
